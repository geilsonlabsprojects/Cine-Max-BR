# Configurações do Firebase (Públicas no Frontend, mas protegidas por Domínio no Console)
VITE_FIREBASE_API_KEY=SUA_API_KEY_AQUI
VITE_FIREBASE_AUTH_DOMAIN=SEU_AUTH_DOMAIN_AQUI
VITE_FIREBASE_DATABASE_URL=SUA_DATABASE_URL_AQUI
VITE_FIREBASE_PROJECT_ID=SEU_PROJECT_ID_AQUI
VITE_FIREBASE_STORAGE_BUCKET=SEU_STORAGE_BUCKET_AQUI
VITE_FIREBASE_MESSAGING_SENDER_ID=SEU_SENDER_ID_AQUI
VITE_FIREBASE_APP_ID=SEU_APP_ID_AQUI

# Chaves Privadas (NUNCA devem ir para o código do cliente)
# Estas devem ser usadas apenas em um servidor Backend (Node.js) se você tiver um.
TMDB_API_KEY=SUA_TMDB_KEY_AQUI
OPENAI_API_KEY=SUA_OPENAI_KEY_AQUI
